# ADA — Autonomous Documentation Agent
# Exemple de configuration d'environnement.
# Copier en .env et compléter. Ne JAMAIS committer .env.

# ─────────────────────────────────────────────────────────────────────────────
#  Provider API keys
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ELEVENLABS_API_KEY=

# Vertex / Fal / Replicate / generic OpenAI-compatible (LM Studio, vLLM, …)
ADA_VERTEX_API_KEY=
ADA_VERTEX_API_URL=https://us-central1-aiplatform.googleapis.com/v1beta1/projects/YOUR_PROJECT/locations/us-central1/endpoints/openapi
ADA_FAL_API_KEY=
ADA_FAL_API_URL=https://fal.run
ADA_REPLICATE_API_KEY=
ADA_REPLICATE_API_URL=https://openai-proxy.replicate.com/v1
ADA_GENERIC_API_KEY=
ADA_GENERIC_API_URL=

# ─────────────────────────────────────────────────────────────────────────────
#  Models per provider — override as needed
# ─────────────────────────────────────────────────────────────────────────────

# Vision (Computer Use loop — only Claude is real today)
ADA_VISION_MODEL=claude-sonnet-4-6
ADA_COMPUTER_USE_BETA=computer-use-2025-01-24
ADA_VERTEX_VISION_MODEL=gemini-2.5-pro       # used when vertex-vision is implemented
ADA_FAL_VISION_MODEL=fal-ai/qwen2-vl-7b      # used when fal-vision is implemented
ADA_REPLICATE_VISION_MODEL=qwen/qwen2-vl-72b # used when replicate-vision is implemented

# Text (Planner / Scripter / Composer)
ADA_CLAUDE_MODEL=claude-sonnet-4-6
ADA_OPENAI_MODEL=gpt-4o
ADA_VERTEX_MODEL=google/gemini-2.5-pro
ADA_FAL_MODEL=meta-llama/Llama-3.1-70B-Instruct
ADA_REPLICATE_MODEL=meta/llama-3.1-405b-instruct
ADA_GENERIC_MODEL=

# TTS (Voicer)
ADA_ELEVENLABS_MODEL=eleven_multilingual_v2
ADA_OPENAI_TTS_MODEL=tts-1
ADA_FAL_TTS_MODEL=fal-ai/kokoro
ADA_VERTEX_TTS_MODEL=fr-FR-Neural2-A         # used when vertex-tts is implemented
ADA_REPLICATE_TTS_MODEL=lucataco/xtts-v2     # used when replicate-tts is implemented

# ─────────────────────────────────────────────────────────────────────────────
#  Provider selection (overridden by ada.yaml when present)
# ─────────────────────────────────────────────────────────────────────────────
ADA_VISION_PROVIDER=claude-computer-use
ADA_TEXT_PROVIDER=claude
ADA_TTS_PROVIDER=elevenlabs

# Disponibles côté text :  claude, openai, vertex, fal, replicate, openai-compat
# Disponibles côté tts  :  elevenlabs, openai-tts, fal-tts, vertex-tts*, replicate-tts*
# Disponibles côté vision : claude-computer-use, vertex-vision*, fal-vision*, replicate-vision*
# (* = stubs jusqu'à session 10)

# ─────────────────────────────────────────────────────────────────────────────
#  Runtime
# ─────────────────────────────────────────────────────────────────────────────
ADA_LANGUAGE=fr
ADA_LOG_LEVEL=info
ADA_HEADLESS=false
ADA_MAX_ITERATIONS=30
ADA_MAX_RETRIES=3
ADA_CACHE_DIR=.ada-cache
ADA_MASK_SELECTORS=

# Set to 1 to run the whole pipeline with in-memory mocks (no API calls).
ADA_MOCK=
