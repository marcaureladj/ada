# ADA — Autonomous Documentation Agent
# Exemple de configuration d'environnement.
# Copier en .env et compléter. Ne JAMAIS committer .env.

# --- Vision agent (Navigator) + Text LLM (Planner, Scripter, Composer) ---
ANTHROPIC_API_KEY=

# --- Alternatives vision/text ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Synthèse vocale (Voicer) ---
ELEVENLABS_API_KEY=

# --- Configuration runtime ADA ---
# Langue par défaut des sorties (fr | en)
ADA_LANGUAGE=fr

# Niveau de log (trace | debug | info | warn | error)
ADA_LOG_LEVEL=info

# Provider par défaut pour chaque étage (override possible via ada.yaml)
ADA_VISION_PROVIDER=claude-computer-use
ADA_TEXT_PROVIDER=claude
ADA_TTS_PROVIDER=elevenlabs

# Dossier de cache local (segments TTS, screenshots)
ADA_CACHE_DIR=.ada-cache
