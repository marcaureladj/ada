{
  "name": "ada",
  "version": "0.0.0",
  "description": "ADA — Autonomous Documentation Agent. CLI : génère une vidéo de documentation à partir d'une URL via un agent IA + HyperFrames.",
  "license": "Apache-2.0",
  "author": "Marc-Aurel",
  "homepage": "https://github.com/marcaureladj/ada#readme",
  "bugs": "https://github.com/marcaureladj/ada/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcaureladj/ada.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["ada", "cli", "documentation", "video", "agent", "playwright", "hyperframes"],
  "type": "module",
  "bin": {
    "ada": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && node ./scripts/postbuild.mjs",
    "clean": "rimraf dist *.tsbuildinfo",
    "start": "node ./dist/cli.js"
  },
  "dependencies": {
    "@ada/core": "workspace:*",
    "@ada/providers": "workspace:*",
    "@ada/templates": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3"
  }
}
