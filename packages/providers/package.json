{
  "name": "@ada/providers",
  "version": "0.0.0",
  "description": "ADA pluggable providers — adapters vision (Claude Computer Use, GPT-4 Vision, Gemini, Qwen), text (Claude, OpenAI, Gemini, Ollama) et TTS (ElevenLabs, OpenAI, Kokoro).",
  "license": "Apache-2.0",
  "author": "Marc-Aurel",
  "homepage": "https://github.com/marcaureladj/ada#readme",
  "bugs": "https://github.com/marcaureladj/ada/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcaureladj/ada.git",
    "directory": "packages/providers"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["ada", "providers", "anthropic", "openai", "elevenlabs"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vision": {
      "types": "./dist/vision/index.d.ts",
      "import": "./dist/vision/index.js"
    },
    "./text": {
      "types": "./dist/text/index.d.ts",
      "import": "./dist/text/index.js"
    },
    "./tts": {
      "types": "./dist/tts/index.d.ts",
      "import": "./dist/tts/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ada/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.32.0",
    "openai": "^6.39.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
